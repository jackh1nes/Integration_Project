<?xml version="1.0" encoding="utf-8"?>
<ConfigSet>
  <Object ObjectID="1" Version="21.1.0" ClassName="Simulink.ConfigSet">
    <P Name="DisabledProps">[]</P>
    <P Name="Description"/>
    <Array PropName="Components" Type="Handle" Dimension="1*10">
      <Object ObjectID="2" Version="21.1.0" ClassName="Simulink.SolverCC">
