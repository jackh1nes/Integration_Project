__MWOPC_PART_BEGIN__ /simulink/bddefaults.xml
<?xml version="1.0" encoding="utf-8"?>
<BlockDiagramDefaults>
  <SystemDefaults>
    <P Name="PaperType">A4</P>
    <P Name="PaperUnits">centimeters</P>
    <P Name="TiledPaperMargins">[8.193532, 8.193532, 8.193532, 8.193532]</P>
  </SystemDefaults>
  <AnnotationDefaults>
    <P Name="HorizontalAlignment">center</P>
    <P Name="VerticalAlignment">middle</P>
  </AnnotationDefaults>
  <MaskDefaults SelfModifiable="off">
    <Display IconFrame="on" IconOpaque="opaque" RunInitForIconRedraw="analyze" IconRotate="none" PortRotate="default" IconUnits="autoscale"/>
    <MaskParameter Evaluate="on" Tunable="on" NeverSave="off" Internal="off" ReadOnly="off" Enabled="on" Visible="on" ToolTip="on"/>
    <DialogControl>
      <ControlOptions Visible="on" Enabled="on" Row="new" HorizontalStretch="on" PromptLocation="top" Orientation="horizontal" Scale="linear" TextType="Plain Text" Expand="off" ShowFilter="on" ShowParameterName="on" WordWrap="on" AlignPrompts="off"/>
    </DialogControl>
  </MaskDefaults>
  <BlockParameterDefaults>
    <Block BlockType="Abs">
      <P Name="ZeroCross">on</P>
      <P Name="SampleTime">-1</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Same as input</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
      <P Name="SaturateOnIntegerOverflow">on</P>
    </Block>
    <Block BlockType="Concatenate">
      <P Name="NumInputs">2</P>
      <P Name="Mode">Vector</P>
      <P Name="ConcatenateDimension">1</P>
    </Block>
    <Block BlockType="Constant">
      <P Name="Value">1</P>
      <P Name="VectorParams1D">on</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Inherit from &apos;Constant value&apos;</P>
      <P Name="LockScale">off</P>
      <P Name="SampleTime">inf</P>
      <P Name="PreserveConstantTs">off</P>
    </Block>
    <Block BlockType="DeadZone">
      <P Name="LowerValue">-0.5</P>
      <P Name="UpperValue">0.5</P>
      <P Name="SaturateOnIntegerOverflow">on</P>
      <P Name="LinearizeAsGain">on</P>
      <P Name="ZeroCross">on</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="Demux">
      <P Name="Outputs">4</P>
      <P Name="DisplayOption">bar</P>
      <P Name="BusSelectionMode">off</P>
    </Block>
    <Block BlockType="Derivative">
      <P Name="CoefficientInTFapproximation">inf</P>
    </Block>
    <Block BlockType="Display">
      <P Name="Format">short</P>
      <P Name="Decimation">10</P>
      <P Name="Floating">off</P>
      <P Name="Lockdown">off</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="From">
      <P Name="GotoTag">A</P>
      <P Name="IconDisplay">Tag</P>
      <P Name="TagVisibility">local</P>
    </Block>
    <Block BlockType="Gain">
      <P Name="Gain">1</P>
      <P Name="Multiplication">Element-wise(K.*u)</P>
      <P Name="ParamMin">[]</P>
      <P Name="ParamMax">[]</P>
      <P Name="ParamDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
      <P Name="SaturateOnIntegerOverflow">off</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="Goto">
      <P Name="GotoTag">A</P>
      <P Name="IconDisplay">Tag</P>
      <P Name="TagVisibility">local</P>
    </Block>
    <Block BlockType="Inport">
      <P Name="Port">1</P>
      <P Name="AllowServiceAccess">off</P>
      <P Name="IconDisplay">Port number</P>
      <P Name="OutputFunctionCall">off</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: auto</P>
      <P Name="LockScale">off</P>
      <P Name="BusOutputAsStruct">off</P>
      <P Name="Unit">inherit</P>
      <P Name="PortDimensions">-1</P>
      <P Name="VarSizeSig">Inherit</P>
      <P Name="SampleTime">-1</P>
      <P Name="SignalType">auto</P>
      <P Name="SamplingMode">auto</P>
      <P Name="LatchByDelayingOutsideSignal">off</P>
      <P Name="LatchInputForFeedbackSignals">off</P>
      <P Name="Interpolate">on</P>
    </Block>
    <Block BlockType="Logic">
      <P Name="Operator">AND</P>
      <P Name="Inputs">2</P>
      <P Name="IconShape">rectangular</P>
      <P Name="AllPortsSameDT">on</P>
      <P Name="OutDataTypeStr">Inherit: Logical (see Configuration Parameters: Optimization)</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="ManualSwitch">
      <P Name="CurrentSetting">1</P>
      <P Name="varsize">off</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="Math">
      <P Name="Operator">exp</P>
      <P Name="AlgorithmMethod">Exact</P>
      <P Name="SignedPower">off</P>
      <P Name="OutputSignalType">auto</P>
      <P Name="SampleTime">-1</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Same as first input</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
      <P Name="SaturateOnIntegerOverflow">on</P>
      <P Name="IntermediateResultsDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="AlgorithmType">Newton-Raphson</P>
      <P Name="Iterations">3</P>
    </Block>
    <Block BlockType="Memory">
      <P Name="InitialCondition">0</P>
      <P Name="InheritSampleTime">off</P>
      <P Name="LinearizeMemory">off</P>
      <P Name="LinearizeAsDelay">off</P>
      <P Name="StateMustResolveToSignalObject">off</P>
    </Block>
    <Block BlockType="Mux">
      <P Name="Inputs">4</P>
      <P Name="DisplayOption">none</P>
      <P Name="UseBusObject">off</P>
      <P Name="BusObject">BusObject</P>
      <P Name="NonVirtualBus">off</P>
    </Block>
    <Block BlockType="Outport">
      <P Name="Port">1</P>
      <P Name="AllowServiceAccess">off</P>
      <P Name="IconDisplay">Port number</P>
      <P Name="OutputFunctionCall">off</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: auto</P>
      <P Name="LockScale">off</P>
      <P Name="BusOutputAsStruct">off</P>
      <P Name="Unit">inherit</P>
      <P Name="PortDimensions">-1</P>
      <P Name="VarSizeSig">Inherit</P>
      <P Name="SampleTime">-1</P>
      <P Name="SignalType">auto</P>
      <P Name="SamplingMode">auto</P>
      <P Name="EnsureOutportIsVirtual">off</P>
      <P Name="OutputWhenDisabled">held</P>
      <P Name="InitialOutput">[]</P>
      <P Name="MustResolveToSignalObject">off</P>
      <P Name="OutputWhenUnConnected">off</P>
      <P Name="OutputWhenUnconnectedValue">0</P>
      <P Name="VectorParamsAs1DForOutWhenUnconnected">on</P>
    </Block>
    <Block BlockType="Product">
      <P Name="Inputs">2</P>
      <P Name="Multiplication">Element-wise(.*)</P>
      <P Name="CollapseMode">All dimensions</P>
      <P Name="CollapseDim">1</P>
      <P Name="InputSameDT">off</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
      <P Name="SaturateOnIntegerOverflow">off</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="RelationalOperator">
      <P Name="Operator">&gt;=</P>
      <P Name="InputSameDT">on</P>
      <P Name="OutDataTypeStr">Inherit: Logical (see Configuration Parameters: Optimization)</P>
      <P Name="ZeroCross">on</P>
      <P Name="SampleTime">-1</P>
      <P Name="RndMeth">Nearest</P>
    </Block>
    <Block BlockType="S-Function">
      <P Name="FunctionName">system</P>
      <P Name="SFunctionModules">&apos;&apos;</P>
      <P Name="PortCounts">[]</P>
      <P Name="MultithreadedSim">auto</P>
    </Block>
    <Block BlockType="Saturate">
      <P Name="UpperLimit">0.5</P>
      <P Name="LowerLimit">-0.5</P>
      <P Name="LinearizeAsGain">on</P>
      <P Name="ZeroCross">on</P>
      <P Name="SampleTime">-1</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Same as input</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
    </Block>
    <Block BlockType="Scope">
      <P Name="DefaultConfigurationName">Simulink.scopes.TimeScopeBlockCfg</P>
    </Block>
    <Block BlockType="Signum">
      <P Name="ZeroCross">on</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="SubSystem">
      <P Name="ShowPortLabels">FromPortIcon</P>
      <P Name="Permissions">ReadWrite</P>
      <P Name="PermitHierarchicalResolution">All</P>
      <P Name="TreatAsAtomicUnit">off</P>
      <P Name="MinAlgLoopOccurrences">off</P>
      <P Name="ScheduleAs">Sample time</P>
      <P Name="SystemSampleTime">-1</P>
      <P Name="RTWSystemCode">Auto</P>
      <P Name="RTWFcnNameOpts">Auto</P>
      <P Name="RTWFileNameOpts">Auto</P>
      <P Name="FunctionInterfaceSpec">void_void</P>
      <P Name="FunctionWithSeparateData">off</P>
      <P Name="MatchGraphicalInterface">off</P>
      <P Name="RTWMemSecFuncInitTerm">Inherit from model</P>
      <P Name="RTWMemSecFuncExecute">Inherit from model</P>
      <P Name="RTWMemSecDataConstants">Inherit from model</P>
      <P Name="RTWMemSecDataInternal">Inherit from model</P>
      <P Name="RTWMemSecDataParameters">Inherit from model</P>
      <P Name="SimViewingDevice">off</P>
      <P Name="DataTypeOverride">UseLocalSettings</P>
      <P Name="DataTypeOverrideAppliesTo">AllNumericTypes</P>
      <P Name="MinMaxOverflowLogging">UseLocalSettings</P>
      <P Name="Opaque">off</P>
      <P Name="RequestExecContextInheritance">off</P>
      <P Name="MaskHideContents">off</P>
      <P Name="SFBlockType">NONE</P>
      <P Name="Variant">off</P>
      <P Name="VariantControlMode">expression</P>
      <P Name="VariantActivationTime">update diagram</P>
      <P Name="AllowZeroVariantControls">off</P>
      <P Name="PropagateVariantConditions">off</P>
      <P Name="TreatAsGroupedWhenPropagatingVariantConditions">on</P>
      <P Name="ContentPreviewEnabled">off</P>
      <P Name="IsWebBlock">off</P>
      <P Name="Latency">0</P>
      <P Name="AutoFrameSizeCalculation">off</P>
      <P Name="IsWebBlockPanel">off</P>
    </Block>
    <Block BlockType="Sum">
      <P Name="IconShape">round</P>
      <P Name="Inputs">++</P>
      <P Name="CollapseMode">All dimensions</P>
      <P Name="CollapseDim">1</P>
      <P Name="OutMin">[]</P>
      <P Name="OutMax">[]</P>
      <P Name="OutDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="AccumDataTypeStr">Inherit: Inherit via internal rule</P>
      <P Name="InputSameDT">off</P>
      <P Name="LockScale">off</P>
      <P Name="RndMeth">Floor</P>
      <P Name="SaturateOnIntegerOverflow">off</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="Terminator"/>
    <Block BlockType="ToWorkspace">
      <P Name="VariableName">simulink_output</P>
      <P Name="MaxDataPoints">1000</P>
      <P Name="Decimation">1</P>
      <P Name="SaveFormat">Array</P>
      <P Name="Save2DSignal">3-D array (concatenate along third dimension)</P>
      <P Name="FixptAsFi">off</P>
      <P Name="NumInputs">1</P>
      <P Name="SampleTime">0</P>
    </Block>
    <Block BlockType="Trigonometry">
      <P Name="Operator">sin</P>
      <P Name="ApproximationMethod">None</P>
      <P Name="NumberOfIterations">11</P>
      <P Name="OutputSignalType">auto</P>
      <P Name="AngleUnit">radian</P>
      <P Name="NumberOfDataPoints">16</P>
      <P Name="RemoveProtectionAgainstOutOfRangeInput">off</P>
      <P Name="SampleTime">-1</P>
    </Block>
    <Block BlockType="UnitDelay">
      <P Name="InitialCondition">0</P>
      <P Name="InputProcessing">Elements as channels (sample based)</P>
      <P Name="SampleTime">1</P>
      <P Name="StateMustResolveToSignalObject">off</P>
    </Block>
  </BlockParameterDefaults>
</BlockDiagramDefaults>

