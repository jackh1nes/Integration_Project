<?xml version="1.0" encoding="utf-8"?>
<ModelInformation Version="1.0">
  <Model>
    <P Name="ModelUUID">233cc7c6-63f7-49fc-8b69-d925f544d2d6</P>
    <Object PropName="HDLParams" ObjectID="1" ClassName="slprops.hdlmdlprops">
      <Array PropName="mdlProps" Type="Cell" Dimension="1*2">
        <Cell Class="char">HDLSubsystem</Cell>
        <Cell Class="char">$bdroot</Cell>
      </Array>
    </Object>
    <P Name="PreLoadFcn">warning(&apos;off&apos;,&apos;MATLAB:dispatcher:InexactMatch&apos;);

</P>
    <P Name="InitFcn">hwinit</P>
    <P Name="LastSavedArchitecture">win64</P>
    <ConfigManagerSettings>
      <P Name="ModifiedByFormat">%&lt;Auto&gt;</P>
      <P Name="ModifiedDateFormat">%&lt;Auto&gt;</P>
      <P Name="ModelVersionFormat">%&lt;AutoIncrement:7.0&gt;</P>
    </ConfigManagerSettings>
    <EditorSettings>
      <P Name="LibraryLinkDisplay">none</P>
      <P Name="ShowLineDimensions">on</P>
      <P Name="MultithreadedSim">on</P>
    </EditorSettings>
    <SimulationSettings>
      <P Name="SimulationMode">external</P>
      <P Name="EnablePacing">on</P>
      <Object PropName="DataLoggingOverride" ObjectID="2" ClassName="Simulink.SimulationData.ModelLoggingInfo">
        <P Name="model_" Class="char">$bdroot</P>
        <Array PropName="logAsSpecifiedByModels_" Type="Cell" Dimension="1*1">
          <Cell Class="char">$bdroot</Cell>
        </Array>
        <Array PropName="logAsSpecifiedByModelsSSIDs_" Type="Cell" Dimension="1*1">
          <Cell Class="char"/>
        </Array>
      </Object>
    </SimulationSettings>
    <ExternalMode>
      <P Name="ExtModeTrigDuration">100000</P>
    </ExternalMode>
    <EngineSettings>
      <P Name="ConfigurableSubsystemUsage">warning</P>
    </EngineSettings>
    <ConcurrentExecutionSettings>
      <Object PropName="DataTransfer" ObjectID="3" ClassName="Simulink.GlobalDataTransfer">
        <P Name="DefaultTransitionBetweenSyncTasks" Class="char">Ensure deterministic transfer (maximum delay)</P>
        <P Name="DefaultTransitionBetweenAsyncTasks" Class="char">Ensure data integrity only</P>
        <P Name="DefaultTransitionBetweenContTasks" Class="char">Ensure deterministic transfer (minimum delay)</P>
        <P Name="DefaultExtrapolationMethodBetweenContTasks" Class="char">None</P>
      </Object>
    </ConcurrentExecutionSettings>
    <System Ref="system_root"/>
  </Model>
</ModelInformation>

